{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    ":timezone(Europe/Moscow)",

    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    ":automergeDigest",
    ":automergePatch",
    ":automergePr",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":rebaseStalePrs",
    ":semanticCommits",

    "local>yukarin/cluster//.renovate/autoMerge.json5",
    "local>yukarin/cluster//.renovate/changelogs.json5",
    "local>yukarin/cluster//.renovate/customManagers.json5",
    "local>yukarin/cluster//.renovate/grafanaDashboards.json5",
    "local>yukarin/cluster//.renovate/groups.json5",
    "local>yukarin/cluster//.renovate/labels.json5",
    "local>yukarin/cluster//.renovate/overrides.json5",
    "local>yukarin/cluster//.renovate/semanticCommits.json5",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  ignorePaths: ["**/resources/**"],
  packageRules: [
    {
      matchDatasources: ["terraform-provider", "terraform-module"],
      registryUrls: ["https://registry.opentofu.org"],
    },
  ],
}
