{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    ":timezone(Europe/Moscow)",

    "github>home-operations/renovate-presets#2.0.1",

    "local>yukarin/cluster//.renovate/autoMerge.json5",
    "local>yukarin/cluster//.renovate/changelogs.json5",
    "local>yukarin/cluster//.renovate/exclusions.json5",
    "local>yukarin/cluster//.renovate/groups.json5",
    "local>yukarin/cluster//.renovate/labels.json5",
  ],
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  packageRules: [
    {
      matchDatasources: ["terraform-provider", "terraform-module"],
      registryUrls: ["https://registry.opentofu.org"],
    },
  ],
}
